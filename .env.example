# Copy to .env (or export in your shell) and fill in before deploying.
# Dev can leave everything unset — DEBUG defaults to off now, so set
# DJANGO_DEBUG=1 locally to get the insecure fallbacks.

# --- Core --------------------------------------------------------------
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-use-python-secrets-token_urlsafe-50
DJANGO_ALLOWED_HOSTS=pathlab.np,www.pathlab.np
DJANGO_CSRF_TRUSTED_ORIGINS=https://pathlab.np,https://www.pathlab.np
DJANGO_SITE_URL=https://pathlab.np

# Number of trusted reverse proxies (e.g. Cloudflare=1, CF+Nginx=2).
# Keeps X-Forwarded-For spoofing from defeating rate limits.
TRUSTED_PROXY_COUNT=1

# --- Email -------------------------------------------------------------
# Must NOT be the console backend in production — settings.py refuses to boot.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_FROM_EMAIL=PathLab <no-reply@pathlab.np>

# --- Payments ----------------------------------------------------------
# 1 in dev to accept stub callbacks; 0 in prod so only HMAC-verified calls activate.
PAYMENT_SANDBOX=0
ESEWA_MERCHANT_ID=your-merchant-id
ESEWA_SECRET_KEY=your-esewa-v2-secret
KHALTI_PUBLIC_KEY=your-khalti-public
KHALTI_SECRET_KEY=your-khalti-secret
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
